spring.application.name=banco



# =============================================
# CONFIGURACIÓN JWT (usando variables de entorno)
# =============================================
# Configuracion JWT (KEY Y EXPIRACION 24hs)
# ${JWT_SECRET:valor_default} = si existe variable JWT_SECRET, la usa; si no, usa valor_default
jwt.secret=${JWT_SECRET:586E3272357538782F413F4428472B4B6250655368566B597033733676397924}
jwt.expiration=${JWT_EXPIRATION:86400000} 




# =============================================
# CONEXIÓNES JPA + POSTGRESQL (usando variables de entorno)
# =============================================
# URL de conexión a PostgreSQL
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:8181/banco_db}
# Usuario de la base de datos
spring.datasource.username=${DB_USERNAME:postgres}
# Contraseña 
spring.datasource.password=${DB_PASSWORD: "Colocar_tu_contraseña"}
# Driver de PostgreSQL
spring.datasource.driver-class-name=org.postgresql.Driver

# CONFIGURACIÓN JPA / HIBERNATE

# Estrategia DDL: 'update' crea/modifica tablas automáticamente
spring.jpa.hibernate.ddl-auto=update
# Mostrar SQL generado en consola (útil para desarrollo)
spring.jpa.show-sql=true
# Formatear el SQL para que sea legible
spring.jpa.properties.hibernate.format_sql=true
# Dialecto de PostgreSQL
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# LOGGING (PARA DEBUG)

# Ver las consultas SQL que se ejecutan
logging.level.org.hibernate.SQL=DEBUG
# Ver los parámetros que se envían a las consultas
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE
# Ver transacciones
logging.level.org.springframework.transaction=DEBUG